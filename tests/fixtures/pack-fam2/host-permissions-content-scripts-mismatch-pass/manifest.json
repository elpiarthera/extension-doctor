{
  "manifest_version": 3,
  "name": "GPTPowerUps",
  "version": "0.9.0.0",
  "description": "AI superpowers for ChatGPT, Claude & Grok.",
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://claude.ai/*",
        "https://grok.com/*"
      ],
      "js": ["ui/sidebar-mount.tsx"],
      "run_at": "document_idle"
    }
  ],
  "permissions": ["storage", "unlimitedStorage", "scripting", "alarms"],
  "optional_permissions": ["tabs"],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://claude.ai/*",
    "https://grok.com/*",
    "https://example-deployment-123.convex.cloud/*"
  ]
}
