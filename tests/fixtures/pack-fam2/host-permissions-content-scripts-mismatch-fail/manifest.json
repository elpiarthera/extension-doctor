{
  "manifest_version": 3,
  "name": "GPTPowerUps",
  "version": "0.9.0.0",
  "description": "AI superpowers for ChatGPT, Claude & Grok. 0-100 Power-Up scores, cross-host orchestration, prompt library.",
  "default_locale": "en",
  "icons": {
    "16": "public/icons/icon-16.png",
    "32": "public/icons/icon-32.png",
    "48": "public/icons/icon-48.png",
    "128": "public/icons/icon-128.png"
  },
  "action": {
    "default_icon": {
      "16": "public/icons/icon-16.png",
      "32": "public/icons/icon-32.png",
      "48": "public/icons/icon-48.png",
      "128": "public/icons/icon-128.png"
    },
    "default_title": "__MSG_ext_name__"
  },
  "background": {
    "service_worker": "src/background/service-worker.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://claude.ai/*",
        "https://grok.com/*"
      ],
      "js": [
        "ui/sidebar-mount.tsx"
      ],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "storage",
    "unlimitedStorage",
    "scripting",
    "alarms"
  ],
  "optional_permissions": [
    "tabs"
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://claude.ai/*",
    "https://grok.com/*",
    "https://*.x.ai/*",
    "https://files.oaiusercontent.com/*",
    "https://REDACTED-DEPLOYMENT.convex.cloud/*"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "public/icons/*",
        "assets/brand/*"
      ],
      "matches": [
        "https://chatgpt.com/*",
        "https://claude.ai/*",
        "https://grok.com/*"
      ]
    }
  ]
}
