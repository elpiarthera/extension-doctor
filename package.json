{
  "name": "extension-doctor",
  "version": "0.1.1",
  "description": "Finds the bugs that pass your demo and fail in the store: unfiltered broadcasts, missing i18n keys, invalidated-context crashes.",
  "keywords": [
    "browser extension",
    "chrome extension",
    "manifest v3",
    "mv3",
    "extension linter",
    "extension audit",
    "chrome web store",
    "web store review",
    "firefox add-on",
    "static analysis",
    "i18n",
    "permissions",
    "service worker",
    "content script",
    "doctor",
    "cli"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/elpiarthera/extension-doctor.git"
  },
  "license": "SEE LICENSE IN LICENSE",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "extension-doctor": "./bin/extension-doctor.js"
  },
  "files": [
    "bin",
    "dist",
    "LICENSE",
    "NOTICE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "start": "node bin/extension-doctor.js",
    "check:readme": "node scripts/check-readme.mjs",
    "prepublishOnly": "npm test && npm run check:readme",
    "prepack": "npm run build"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "@types/node": "^20.14.0"
  }
}
